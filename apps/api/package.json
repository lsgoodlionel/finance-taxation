{
  "name": "@finance-taxation/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:unit",
    "test:unit": "tsx --test --test-concurrency=1 $(find src -name '*.test.ts' ! -name '*.integration.test.ts')",
    "test:integration": "tsx --test --test-concurrency=1 $(find src -name '*.integration.test.ts')",
    "dev": "tsx watch src/main.ts",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@types/pdf-parse": "^1.1.5",
    "busboy": "^1.6.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.8.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
