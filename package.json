{
  "name": "finance-taxation-workspace",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:prototype": "node --check src/scripts/app.js",
    "check:backend-js": "find backend/src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "check:data": "node tools/check-json.mjs backend/data",
    "check:progress": "node tools/check-progress-board.mjs docs/v4-progress-board.md",
    "typecheck:v2": "npm run -w @finance-taxation/web typecheck && npm run -w @finance-taxation/api typecheck",
    "test": "npm run test -w @finance-taxation/api",
    "test:api": "npm run -w @finance-taxation/api test:serial",
    "test:web:runner": "node --test tools/v4/run-web-tests.test.mjs",
    "test:web": "npm run test:web:runner && node tools/v4/run-web-tests.mjs",
    "test:db": "node --import tsx --test tools/v4/workflow-runtime-db.test.ts",
    "test:v4:tools": "node --import tsx --test tools/v4/*.test.ts",
    "test:unit": "npm run test:api && npm run test:web",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "v4:report": "node --import tsx tools/v4/generate-acceptance-report.ts",
    "v4:ops:init-sources": "node --import tsx tools/v4/run-init-ops-sources.mjs",
    "v4:ops:record": "node --import tsx tools/v4/record-ops-source.ts",
    "v4:ops": "bash tools/v4/run-production-gates-generation.sh",
    "v4:feedback:submit": "node --import tsx tools/v4/submit-failures-to-feedback.ts",
    "v4:test:db:start": "docker compose -p finance-taxation-v4-test -f docker-compose.test.yml up -d db",
    "v4:test:app:start": "docker compose -p finance-taxation-v4-test -f docker-compose.test.yml up -d --build api web",
    "v4:test:stack:start": "npm run v4:test:db:start && npm run v4:test:app:start",
    "v4:test:stack:stop": "docker compose -p finance-taxation-v4-test -f docker-compose.test.yml down -v",
    "v4:test:db:reset": "V4_TEST_DATABASE_URL=${V4_TEST_DATABASE_URL:-postgres://finance_taxation:finance_taxation@127.0.0.1:55433/finance_taxation_v4_test} tsx tools/v4/reset-test-db.ts",
    "v4:test:seed": "V4_TEST_DATABASE_URL=${V4_TEST_DATABASE_URL:-postgres://finance_taxation:finance_taxation@127.0.0.1:55433/finance_taxation_v4_test} tsx tools/v4/seed-acceptance-data.ts",
    "v4:test:setup": "npm run v4:test:db:start && npm run v4:test:db:reset && npm run v4:test:seed && npm run v4:test:app:start",
    "typecheck:v4:tools": "node tools/v4/typecheck.mjs",
    "test:load": "node --import tsx tools/v4/production-gates.ts load",
    "test:backup-restore": "node --import tsx tools/v4/production-gates.ts backup-restore",
    "test:connectors": "node --import tsx tools/v4/production-gates.ts connectors",
    "test:ai-evals": "node --import tsx tools/v4/production-gates.ts ai-evals",
    "verify:v4": "npm run typecheck:v2 && npm run typecheck:v4:tools && npm run test:unit && npm run test:db && npm run test:v4:tools && npm run v4:report && node tools/v4/check-plan-artifacts.mjs && npm run check:progress",
    "verify": "npm run check:prototype && npm run check:backend-js && npm run check:data && npm run check:progress"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
